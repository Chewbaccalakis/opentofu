  {{- if eq $secret.Key "HV3_TOKEN_SECRET" }}"hv3_token_secret": "{{$secret.Value}}",{{ end }}
  {{- if eq $secret.Key "HV4_TOKEN_SECRET" }}"hv4_token_secret": "{{$secret.Value}}",{{ end }}
  {{- if eq $secret.Key "HV5_TOKEN_SECRET" }}"hv5_token_secret": "{{$secret.Value}}",{{ end }}
